# 聚宽 JQData 账号（复制本文件为 .env 后填写）
# 申请试用: https://www.joinquant.com/default/index/sdk
JQ_USERNAME=your_joinquant_phone_or_email
JQ_PASSWORD=your_joinquant_password

# 果仁网（批量回测脚本 scripts/guorn_batch_backtest.py 用）
# 从浏览器 Network → runtest → Request Headers 复制，勿提交到 Git
GUORN_COOKIE=_xsrf=...; user=...; token=...
GUORN_XSRF_TOKEN=2|...|...|...